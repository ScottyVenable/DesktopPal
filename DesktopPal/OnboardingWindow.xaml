<Window x:Class="DesktopPal.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPal — Welcome"
        Height="360" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#2D3748"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11.5"/>
            <Setter Property="Padding"         Value="20,7"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Rounded card with soft drop shadow, matching CompanionWindow / SettingsWindow tone. -->
    <Border CornerRadius="16" Background="#F7FAFC" Margin="16"
            BorderBrush="#C8DDEE" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Color="#000" Opacity="0.18"
                              ShadowDepth="3" Direction="270"/>
        </Border.Effect>

        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Step indicator + title row -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <Ellipse Name="Dot1" Width="8" Height="8" Fill="#4299E1" Margin="0,0,6,0"/>
                <Ellipse Name="Dot2" Width="8" Height="8" Fill="#CBD5E0" Margin="0,0,6,0"/>
                <Ellipse Name="Dot3" Width="8" Height="8" Fill="#CBD5E0"/>
            </StackPanel>

            <!-- Step content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                <TextBlock Name="StepTitle" FontSize="20" FontWeight="SemiBold"
                           Foreground="#2D3748" Margin="0,0,0,12"/>
                <TextBlock Name="StepBody" FontSize="12.5" Foreground="#4A5568"
                           TextWrapping="Wrap" LineHeight="20"/>
            </StackPanel>

            <!-- Hotkey hint row, only visible on step 2 -->
            <Border Grid.Row="2" Name="HotkeyCard" Visibility="Collapsed"
                    Background="#EBF4FF" CornerRadius="10" Padding="12,9"
                    Margin="0,14,0,0">
                <TextBlock Name="HotkeyText" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="#2B6CB0"/>
            </Border>

            <!-- Buttons row -->
            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Name="BackButton" Content="Back"
                        Click="Back_Click"
                        Background="#EDF2F7" Foreground="#4A5568"/>

                <Button Grid.Column="2" Name="NextButton" Content="Next"
                        Click="Next_Click"
                        Background="#4299E1" Foreground="White"/>
            </Grid>
        </Grid>
    </Border>
</Window>
