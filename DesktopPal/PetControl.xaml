<UserControl x:Class="DesktopPal.PetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="250" Width="200">
    <Grid Name="PetGrid" Cursor="Hand">
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <!-- Chat Reply Bubble -->
            <Border Name="ChatBubble" Background="#F0F8FF" CornerRadius="15" Padding="10" Margin="0,0,0,10" BorderBrush="#87CEFA" BorderThickness="2" Visibility="Collapsed" MaxWidth="180">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" Color="LightGray" Opacity="0.5" ShadowDepth="2"/>
                </Border.Effect>
                <TextBlock Name="ChatText" FontSize="12" Foreground="#333" TextWrapping="Wrap" Text="Hello!"/>
            </Border>

            <!-- Status & Interaction Bubble -->
            <Border Name="StatusBubble" Background="White" CornerRadius="10" Padding="5" Margin="0,0,0,5" BorderBrush="Gray" BorderThickness="1" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Name="StatusText" FontSize="10" Text="I'm hungry!"/>
                    <ProgressBar Name="HungerBar" Height="5" Width="50" Margin="0,2"/>
                    <UniformGrid Columns="2">
                        <Button Content="Feed" Click="Feed_Click" FontSize="8"/>
                        <Button Content="Clean" Click="Clean_Click" FontSize="8"/>
                    </UniformGrid>
                    <DockPanel Margin="0,5,0,0">
                        <Button Content="Say" Click="Say_Click" DockPanel.Dock="Right" FontSize="8"/>
                        <TextBox Name="ChatInput" FontSize="8" Padding="2" KeyDown="ChatInput_KeyDown"/>
                    </DockPanel>
                </StackPanel>
            </Border>
            
            <!-- Pet Graphic -->
            <Grid Width="60" Height="80">
                <Ellipse Fill="White" Stroke="Black" StrokeThickness="2" Name="PetBody"/>
                <Ellipse Fill="Black" Width="5" Height="5" Margin="15,25,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Ellipse Fill="Black" Width="5" Height="5" Margin="0,25,15,0" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
