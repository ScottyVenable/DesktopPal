<UserControl x:Class="DesktopPal.PetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="250" Width="200" RenderTransformOrigin="0.5,1">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="DepthScale" ScaleX="1.0" ScaleY="1.0"/>
    </UserControl.RenderTransform>
    <Grid Name="PetGrid" Cursor="Hand">
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <!-- Chat Reply Bubble -->
            <Border Name="ChatBubble" Background="#F0F8FF" CornerRadius="15" Padding="10" Margin="0,0,0,-20" BorderBrush="#87CEFA" BorderThickness="2" Visibility="Collapsed" MaxWidth="180" Panel.ZIndex="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="5" Color="LightGray" Opacity="0.5" ShadowDepth="2"/>
                </Border.Effect>
                <TextBlock Name="ChatText" FontSize="12" Foreground="#333" TextWrapping="Wrap" Text="Hello!"/>
            </Border>

            <!-- Status & Interaction Bubble -->
            <Border Name="StatusBubble" Background="White" CornerRadius="10" Padding="5" Margin="0,0,0,5" BorderBrush="Gray" BorderThickness="1" Visibility="Collapsed" Panel.ZIndex="10">
                <StackPanel>
                    <TextBlock Name="StatusText" FontSize="10" Text="I'm hungry!"/>
                    <ProgressBar Name="HungerBar" Height="5" Width="50" Margin="0,2"/>
                    <UniformGrid Columns="2">
                        <Button Content="Feed" Click="Feed_Click" FontSize="8"/>
                        <Button Content="Clean" Click="Clean_Click" FontSize="8"/>
                    </UniformGrid>
                    <DockPanel Margin="0,5,0,0">
                        <Button Content="Say" Click="Say_Click" DockPanel.Dock="Right" FontSize="8"/>
                        <TextBox Name="ChatInput" FontSize="8" Padding="2" KeyDown="ChatInput_KeyDown"/>
                    </DockPanel>
                </StackPanel>
            </Border>
            
            <!-- SVG Pet Graphic (3/4 Perspective Design) -->
            <Viewbox Width="100" Height="100" Name="PetVisualRoot">
                <Canvas Width="100" Height="100">
                    <!-- Shadow -->
                    <Ellipse Fill="#33000000" Width="60" Height="20" Canvas.Left="20" Canvas.Top="75"/>
                    
                    <!-- Body (Rounded Blob) -->
                    <Path Fill="#FFB2FFB2" Stroke="#FF2D5A2D" StrokeThickness="2" Name="BodyPath">
                        <Path.Data>
                            <PathGeometry Figures="M 50,15 C 25,15 15,35 15,60 C 15,85 30,90 50,90 C 70,90 85,85 85,60 C 85,35 75,15 50,15 Z" />
                        </Path.Data>
                    </Path>

                    <!-- Face Container for 3/4 Offset -->
                    <Canvas Name="FaceCanvas" Canvas.Left="10" Canvas.Top="5">
                        <!-- Left Eye -->
                        <Canvas Name="LeftEyeGroup" Canvas.Left="25" Canvas.Top="35">
                            <Ellipse Fill="White" Width="14" Height="18" Name="LeftEyeWhite"/>
                            <Ellipse Fill="Black" Width="6" Height="8" Canvas.Left="5" Canvas.Top="5" Name="LeftEye"/>
                            <TextBlock Name="LeftEmote" Text=">" Visibility="Collapsed" FontSize="12" FontWeight="Bold" Canvas.Left="2" Canvas.Top="2"/>
                        </Canvas>

                        <!-- Right Eye (Smaller/Squashed for 3/4) -->
                        <Canvas Name="RightEyeGroup" Canvas.Left="55" Canvas.Top="38">
                            <Ellipse Fill="White" Width="10" Height="16" Name="RightEyeWhite"/>
                            <Ellipse Fill="Black" Width="4" Height="7" Canvas.Left="4" Canvas.Top="5" Name="RightEye"/>
                            <TextBlock Name="RightEmote" Text="&lt;" Visibility="Collapsed" FontSize="10" FontWeight="Bold" Canvas.Left="1" Canvas.Top="2"/>
                        </Canvas>

                        <!-- Blush -->
                        <Ellipse Fill="#44FFB6C1" Width="10" Height="5" Canvas.Left="22" Canvas.Top="55"/>
                        <Ellipse Fill="#44FFB6C1" Width="7" Height="4" Canvas.Left="58" Canvas.Top="56"/>
                    </Canvas>
                </Canvas>
            </Viewbox>
        </StackPanel>
    </Grid>
</UserControl>
