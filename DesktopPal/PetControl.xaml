<UserControl x:Class="DesktopPal.PetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="150" Height="164" RenderTransformOrigin="0.5,1">
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="DepthScale" ScaleX="1.0" ScaleY="1.0"/>
    </UserControl.RenderTransform>

    <Canvas Width="150" Height="164" Name="PetGrid" Cursor="Hand">

        <!-- ── Speech Bubble (floats above bear) ── -->
        <Border Name="ChatBubble" Canvas.Left="1" Canvas.Top="4"
                Width="148" MaxHeight="86" Visibility="Collapsed"
                Background="White" CornerRadius="16" Padding="11,8"
                BorderBrush="#C8DDEE" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#000" Opacity="0.10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <TextBlock Name="ChatText" FontSize="11" FontFamily="Segoe UI"
                       Foreground="#1E2D50" TextWrapping="Wrap" LineHeight="16"/>
        </Border>

        <!-- Bubble tail -->
        <Path Name="ChatTail" Visibility="Collapsed"
              Data="M 0,0 L 12,0 L 6,9 Z" Fill="White"
              Stroke="#C8DDEE" StrokeThickness="1"
              Canvas.Left="69" Canvas.Top="89"/>

        <!-- ── Bear Sprite (icon-sized: 72px rendered) ── -->
        <Viewbox Name="PetVisualRoot" Canvas.Left="43" Canvas.Top="92"
                 Width="64" Height="64" RenderTransformOrigin="0.5,0.5">
            <Viewbox.RenderTransform>
                <ScaleTransform x:Name="FacingScale" ScaleX="1" ScaleY="1"/>
            </Viewbox.RenderTransform>
            <Canvas Width="100" Height="100">

                <!-- Ground shadow -->
                <Ellipse Fill="#14000000" Width="58" Height="10" Canvas.Left="21" Canvas.Top="89"/>

                <!-- Back feet -->
                <Ellipse Width="20" Height="13" Canvas.Left="24" Canvas.Top="83"
                         Fill="#3A6CAB" Stroke="#23406F" StrokeThickness="1.6"/>
                <Ellipse Width="20" Height="13" Canvas.Left="56" Canvas.Top="83"
                         Fill="#3A6CAB" Stroke="#23406F" StrokeThickness="1.6"/>

                <!-- ── Left ear (drawn first, behind body) ── -->
                <Ellipse Width="22" Height="22" Canvas.Left="13" Canvas.Top="5"
                         Stroke="#23406F" StrokeThickness="2.2">
                    <Ellipse.Fill><LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                        <GradientStop Color="#6EA3E2" Offset="0"/>
                        <GradientStop Color="#4E85C8" Offset="1"/>
                    </LinearGradientBrush></Ellipse.Fill>
                </Ellipse>
                <Ellipse Fill="#F6EFD6" Width="12" Height="12" Canvas.Left="18" Canvas.Top="10"/>

                <!-- ── Right ear ── -->
                <Ellipse Width="22" Height="22" Canvas.Left="65" Canvas.Top="5"
                         Stroke="#23406F" StrokeThickness="2.2">
                    <Ellipse.Fill><LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                        <GradientStop Color="#6EA3E2" Offset="0"/>
                        <GradientStop Color="#4E85C8" Offset="1"/>
                    </LinearGradientBrush></Ellipse.Fill>
                </Ellipse>
                <Ellipse Fill="#F6EFD6" Width="12" Height="12" Canvas.Left="70" Canvas.Top="10"/>

                <!-- ── Body ── -->
                <Ellipse Name="BodyPath" Width="76" Height="74" Canvas.Left="12" Canvas.Top="18"
                         Stroke="#23406F" StrokeThickness="2.6">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0.25,0" EndPoint="0.75,1">
                            <GradientStop x:Name="BodyTop"    Color="#7AADEA" Offset="0"/>
                            <GradientStop x:Name="BodyBottom" Color="#4E85C8" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Belly highlight -->
                <Ellipse Fill="#14FFFFFF" Width="30" Height="24" Canvas.Left="36" Canvas.Top="43"/>

                <!-- Eye patches -->
                <Ellipse Fill="#F6EFD6" Width="24" Height="24" Canvas.Left="18" Canvas.Top="28"/>
                <Ellipse Fill="#F6EFD6" Width="24" Height="24" Canvas.Left="58" Canvas.Top="28"/>

                <!-- ── Muzzle (cream face patch) ── -->
                <Ellipse Fill="#F6EFD6" Stroke="#D7CFB5" StrokeThickness="1.1"
                         Width="32" Height="24" Canvas.Left="34" Canvas.Top="49"/>

                <!-- Paws -->
                <Path Data="M 16,61 C 12,67 10,72 12,79 C 14,86 23,87 28,82 C 31,79 31,74 28,70 C 25,67 22,64 19,59"
                      Fill="Transparent" Stroke="#23406F" StrokeThickness="2.2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path Data="M 84,61 C 88,67 90,72 88,79 C 86,86 77,87 72,82 C 69,79 69,74 72,70 C 75,67 78,64 81,59"
                      Fill="Transparent" Stroke="#23406F" StrokeThickness="2.2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                <!-- ══════════════════════════════════════════
                     EXPRESSION GROUPS — one visible at a time
                     ══════════════════════════════════════════ -->

                <!-- ── NORMAL ── -->
                <Canvas Name="NormalFace">
                    <!-- Left eye -->
                    <Ellipse Fill="#1C2B4A" Width="14" Height="16" Canvas.Left="23" Canvas.Top="31"/>
                    <Ellipse Fill="White"   Width="5"  Height="5"  Canvas.Left="25" Canvas.Top="33"/>
                    <Ellipse Fill="White"   Width="2.8" Height="2.8" Canvas.Left="32" Canvas.Top="40"/>
                    <!-- Right eye -->
                    <Ellipse Fill="#1C2B4A" Width="14" Height="16" Canvas.Left="63" Canvas.Top="31"/>
                    <Ellipse Fill="White"   Width="5"  Height="5"  Canvas.Left="65" Canvas.Top="33"/>
                    <Ellipse Fill="White"   Width="2.8" Height="2.8" Canvas.Left="72" Canvas.Top="40"/>
                    <!-- Nose -->
                    <Ellipse Fill="#23406F" Width="5.5" Height="4.5" Canvas.Left="47.2" Canvas.Top="56"/>
                    <!-- Smile -->
                    <Path Data="M 41,62 Q 50,69 59,62" Fill="Transparent"
                          Stroke="#23406F" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <!-- ── HAPPY  ( ^  ^ ) ── -->
                <Canvas Name="HappyFace" Visibility="Collapsed">
                    <Path Data="M 23,40 Q 31,32 39,40" Fill="Transparent"
                          Stroke="#1C2B4A" StrokeThickness="3"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M 61,40 Q 69,32 77,40" Fill="Transparent"
                          Stroke="#1C2B4A" StrokeThickness="3"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <!-- Cheek blush -->
                    <Ellipse Fill="#55FFB0C0" Width="12" Height="6" Canvas.Left="15" Canvas.Top="49"/>
                    <Ellipse Fill="#55FFB0C0" Width="12" Height="6" Canvas.Left="73" Canvas.Top="49"/>
                    <!-- Big smile -->
                    <Path Data="M 40,60 Q 50,71 60,60" Fill="Transparent"
                          Stroke="#CC3366" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <!-- ── HUNGRY / SAD ── -->
                <Canvas Name="HungryFace" Visibility="Collapsed">
                    <!-- Eyes normal shape but pupils drop down -->
                    <Ellipse Fill="#1C2B4A" Width="12" Height="14" Canvas.Left="24" Canvas.Top="35"/>
                    <Ellipse Fill="White"   Width="4"  Height="4"  Canvas.Left="25" Canvas.Top="36"/>
                    <Ellipse Fill="#1C2B4A" Width="12" Height="14" Canvas.Left="64" Canvas.Top="35"/>
                    <Ellipse Fill="White"   Width="4"  Height="4"  Canvas.Left="65" Canvas.Top="36"/>
                    <!-- Worried inner brows -->
                    <Path Data="M 23,28 Q 30,23 37,28" Fill="Transparent"
                          Stroke="#23406F" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M 63,28 Q 70,23 77,28" Fill="Transparent"
                          Stroke="#23406F" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <!-- Nose -->
                    <Ellipse Fill="#23406F" Width="5.5" Height="4.5" Canvas.Left="47.2" Canvas.Top="56"/>
                    <!-- Sad mouth -->
                    <Path Data="M 42,64 Q 50,58 58,64" Fill="Transparent"
                          Stroke="#23406F" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <!-- ── SLEEPING  ( - - ) ── -->
                <Canvas Name="SleepingFace" Visibility="Collapsed">
                    <Path Data="M 23,40 Q 30,44 37,40" Fill="Transparent"
                          Stroke="#1C2B4A" StrokeThickness="3"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M 63,40 Q 70,44 77,40" Fill="Transparent"
                          Stroke="#1C2B4A" StrokeThickness="3"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Ellipse Fill="#23406F" Width="5.5" Height="4.5" Canvas.Left="47.2" Canvas.Top="56"/>
                    <TextBlock Text="z" FontSize="10" FontWeight="Bold" Foreground="#8899CC"
                               Canvas.Left="78" Canvas.Top="29"/>
                    <TextBlock Text="Z" FontSize="14" FontWeight="Bold" Foreground="#8899CC"
                               Canvas.Left="84" Canvas.Top="15"/>
                </Canvas>

                <!-- ── EXCITED  ( O O ) ── -->
                <Canvas Name="ExcitedFace" Visibility="Collapsed">
                    <Ellipse Fill="#1C2B4A" Width="16" Height="18" Canvas.Left="22" Canvas.Top="29"/>
                    <Ellipse Fill="White"   Width="6"  Height="6"  Canvas.Left="24" Canvas.Top="31"/>
                    <Ellipse Fill="#1C2B4A" Width="16" Height="18" Canvas.Left="62" Canvas.Top="29"/>
                    <Ellipse Fill="White"   Width="6"  Height="6"  Canvas.Left="64" Canvas.Top="31"/>
                    <Ellipse Stroke="#23406F" StrokeThickness="1.5" Fill="#FFEEF4"
                             Width="12" Height="10" Canvas.Left="44" Canvas.Top="60"/>
                </Canvas>

                <!-- ── LOVE  ( ♥ ♥ ) ── -->
                <Canvas Name="LoveFace" Visibility="Collapsed">
                    <!-- Left heart -->
                    <Path Fill="#FF5588" Canvas.Left="24" Canvas.Top="30"
                          Data="M 11,4 C 11,1 7.5,0 5.5,2 C 3.5,0 0,1 0,4 C 0,7 5.5,12 5.5,12 C 5.5,12 11,7 11,4 Z"/>
                    <!-- Right heart (smaller) -->
                    <Path Fill="#FF5588" Canvas.Left="64" Canvas.Top="30"
                          Data="M 8,3 C 8,1 5.5,0 4,1.5 C 2.5,0 0,1 0,3 C 0,5 4,9 4,9 C 4,9 8,5 8,3 Z"/>
                    <Path Data="M 39,61 Q 50,72 61,61" Fill="Transparent"
                          Stroke="#CC3366" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Ellipse Fill="#88FFB0C0" Width="12" Height="6" Canvas.Left="15" Canvas.Top="49"/>
                    <Ellipse Fill="#88FFB0C0" Width="12" Height="6" Canvas.Left="73" Canvas.Top="49"/>
                </Canvas>

            </Canvas>
        </Viewbox>
    </Canvas>
</UserControl>
