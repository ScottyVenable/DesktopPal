<Window x:Class="DesktopPal.CompanionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DesktopPal"
        Width="320" Height="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Stat bar foreground overrides -->
        <Style x:Key="HungerBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FEEBC8"/>
            <Setter Property="Foreground">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F6AD55" Offset="0"/>
                        <GradientStop Color="#DD6B20" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HappyBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#C6F6D5"/>
            <Setter Property="Foreground">
                <Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#68D391" Offset="0"/>
                    <GradientStop Color="#38A169" Offset="1"/>
                </LinearGradientBrush></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HygieneBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#BEE3F8"/>
            <Setter Property="Foreground">
                <Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#63B3ED" Offset="0"/>
                    <GradientStop Color="#3182CE" Offset="1"/>
                </LinearGradientBrush></Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EnergyBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E9D8FD"/>
            <Setter Property="Foreground">
                <Setter.Value><LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#B794F4" Offset="0"/>
                    <GradientStop Color="#805AD5" Offset="1"/>
                </LinearGradientBrush></Setter.Value>
            </Setter>
        </Style>

        <!-- Action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="#2E4E85"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="#EBF4FF" CornerRadius="12"
                                Padding="8,7">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path x:Name="Ico"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="#4A80C4" Stretch="Uniform" Width="18" Height="18"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="9.5"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"  Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="Ico" Property="Fill"       Value="#2B6CB0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#BEE3F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="#4A80C4" CornerRadius="10"
                                Width="34" Height="34">
                            <TextBlock Text="→" FontSize="15" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="1,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2B6CB0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2C5282"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer shadow wrapper -->
    <Border Margin="10" CornerRadius="22">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" Color="#000" Opacity="0.18" ShadowDepth="4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="106"/>   <!-- Header  -->
                <RowDefinition Height="108"/>   <!-- Stats   -->
                <RowDefinition Height="*"/>     <!-- Chat    -->
                <RowDefinition Height="76"/>    <!-- Actions -->
            </Grid.RowDefinitions>

            <!-- ══ HEADER ══ -->
            <Border Grid.Row="0" CornerRadius="22,22,0,0" MouseDown="Header_MouseDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#DBEAFE" Offset="0"/>
                        <GradientStop Color="#EBF4FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,10,16,10">
                    <!-- Mini bear avatar -->
                    <Viewbox Width="72" Height="72" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Canvas Width="100" Height="100">
                            <!-- Left ear -->
                            <Ellipse Width="26" Height="26" Canvas.Left="10" Canvas.Top="1" Stroke="#2E4E85" StrokeThickness="2.5">
                                <Ellipse.Fill><LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1"><GradientStop Color="#7AADEA" Offset="0"/><GradientStop Color="#4E85C8" Offset="1"/></LinearGradientBrush></Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Fill="#F0ECE0" Width="14" Height="14" Canvas.Left="16" Canvas.Top="7"/>
                            <!-- Right ear -->
                            <Ellipse Width="21" Height="21" Canvas.Left="63" Canvas.Top="5" Stroke="#2E4E85" StrokeThickness="2">
                                <Ellipse.Fill><LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1"><GradientStop Color="#7AADEA" Offset="0"/><GradientStop Color="#4E85C8" Offset="1"/></LinearGradientBrush></Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Fill="#F0ECE0" Width="11" Height="11" Canvas.Left="68" Canvas.Top="10"/>
                            <!-- Body -->
                            <Ellipse Width="76" Height="74" Canvas.Left="12" Canvas.Top="18" Stroke="#2E4E85" StrokeThickness="2.5">
                                <Ellipse.Fill><LinearGradientBrush StartPoint="0.25,0" EndPoint="0.75,1"><GradientStop Color="#7AADEA" Offset="0"/><GradientStop Color="#4E85C8" Offset="1"/></LinearGradientBrush></Ellipse.Fill>
                            </Ellipse>
                            <!-- Belly highlight -->
                            <Ellipse Fill="#1AFFFFFF" Width="32" Height="26" Canvas.Left="34" Canvas.Top="44"/>
                            <!-- Muzzle -->
                            <Ellipse Fill="#F0ECE0" Stroke="#DDD5B8" StrokeThickness="1" Width="40" Height="28" Canvas.Left="30" Canvas.Top="52"/>
                            <!-- Eyes -->
                            <Ellipse Fill="#F0ECE0" Width="22" Height="24" Canvas.Left="22" Canvas.Top="29"/>
                            <Ellipse Fill="#1C2B4A" Width="13" Height="15" Canvas.Left="26.5" Canvas.Top="33.5"/>
                            <Ellipse Fill="White"   Width="5"  Height="5"  Canvas.Left="27"   Canvas.Top="34.5"/>
                            <Ellipse Fill="#F0ECE0" Width="18" Height="20" Canvas.Left="55" Canvas.Top="31"/>
                            <Ellipse Fill="#1C2B4A" Width="10" Height="12" Canvas.Left="58.5" Canvas.Top="34.5"/>
                            <Ellipse Fill="White"   Width="4"  Height="4"  Canvas.Left="59"   Canvas.Top="35.5"/>
                            <!-- Nose -->
                            <Ellipse Fill="#2E4E85" Width="5" Height="4" Canvas.Left="47.5" Canvas.Top="58"/>
                            <!-- Smile -->
                            <Path Data="M 40,65 Q 50,72 60,65" Fill="Transparent" Stroke="#2E4E85" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Name / level / age -->
                    <StackPanel Margin="82,0,44,0" VerticalAlignment="Center">
                        <TextBlock Name="PetNameLabel" Text="Buddy"
                                   FontSize="20" FontWeight="Bold" Foreground="#1E2D50" FontFamily="Segoe UI"/>
                        <TextBlock Name="PetLevelLabel" Text="Level 1"
                                   FontSize="11.5" Foreground="#4A80C4" Margin="0,3,0,2" FontFamily="Segoe UI"/>
                        <TextBlock Name="PetAgeLabel" Text=""
                                   FontSize="10" Foreground="#90A4C0" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse Name="AIStatusDot" Width="8" Height="8"
                                     Fill="#A0AEC0" VerticalAlignment="Center"
                                     ToolTip="LM Studio status: unknown"/>
                            <TextBlock Name="AIStatusLabel" Text="AI: checking"
                                       FontSize="10" Foreground="#90A4C0"
                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Close button -->
                    <Button Click="Close_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,2,0,0" Cursor="Hand" ToolTip="Close (hotkey to reopen)">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Width="26" Height="26">
                                    <TextBlock Text="✕" FontSize="13" Foreground="#90A4C0"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#FFD0D8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ══ STATS ══ -->
            <Border Grid.Row="1" Background="White" Padding="20,14,20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Hunger"  FontSize="10.5" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <ProgressBar Name="HungerBar"  Grid.Row="0" Grid.Column="1" Style="{StaticResource HungerBar}"  VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Name="HungerVal"    Grid.Row="0" Grid.Column="2" FontSize="9.5" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Segoe UI"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Happy"   FontSize="10.5" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <ProgressBar Name="HappyBar"   Grid.Row="1" Grid.Column="1" Style="{StaticResource HappyBar}"   VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Name="HappyVal"     Grid.Row="1" Grid.Column="2" FontSize="9.5" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Segoe UI"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Hygiene" FontSize="10.5" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <ProgressBar Name="HygieneBar" Grid.Row="2" Grid.Column="1" Style="{StaticResource HygieneBar}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Name="HygieneVal"   Grid.Row="2" Grid.Column="2" FontSize="9.5" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Segoe UI"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Energy"  FontSize="10.5" Foreground="#64748B" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <ProgressBar Name="EnergyBar"  Grid.Row="3" Grid.Column="1" Style="{StaticResource EnergyBar}"  VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Name="EnergyVal"    Grid.Row="3" Grid.Column="2" FontSize="9.5" Foreground="#94A3B8" VerticalAlignment="Center" HorizontalAlignment="Right" FontFamily="Segoe UI"/>
                </Grid>
            </Border>

            <!-- ══ CHAT ══ -->
            <Border Grid.Row="2" Background="#F8FAFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Message history -->
                    <ScrollViewer Name="ChatScroll" Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="14,10,14,6">
                        <StackPanel Name="ChatStack" />
                    </ScrollViewer>

                    <!-- Input row -->
                    <Border Grid.Row="1" Background="White"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                            Padding="14,10">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource SendBtn}"
                                    Click="Send_Click" Margin="8,0,0,0"/>
                            <Border BorderBrush="#CBD5E0" BorderThickness="1" CornerRadius="10"
                                    Background="White" Padding="10,6">
                                <TextBox Name="ChatInput" BorderThickness="0" Background="Transparent"
                                         FontSize="11.5" FontFamily="Segoe UI"
                                         VerticalContentAlignment="Center"
                                         KeyDown="ChatInput_KeyDown"
                                         Text="" AcceptsReturn="False">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Resources>
                                                <VisualBrush x:Key="Placeholder" Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Say something..." Foreground="#CBD5E0"
                                                                   FontSize="11.5" FontFamily="Segoe UI"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource Placeholder}"/>
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ ACTIONS ══ -->
            <Border Grid.Row="3" CornerRadius="0,0,22,22" Padding="14,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F7FF" Offset="0"/>
                        <GradientStop Color="#EBF4FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <UniformGrid Columns="5">
                    <Button Tag="{StaticResource Icon.Food}"     Content="Feed"     Style="{StaticResource ActionBtn}" Click="Feed_Click"     Margin="3,0"/>
                    <Button Tag="{StaticResource Icon.Clean}"    Content="Clean"    Style="{StaticResource ActionBtn}" Click="Clean_Click"    Margin="3,0"/>
                    <Button Tag="{StaticResource Icon.Plant}"    Content="Plant"    Style="{StaticResource ActionBtn}" Click="Plant_Click"    Margin="3,0"/>
                    <Button Tag="{StaticResource Icon.Call}"     Content="Call"     Style="{StaticResource ActionBtn}" Click="Call_Click"     Margin="3,0"/>
                    <Button Tag="{StaticResource Icon.Settings}" Content="Settings" Style="{StaticResource ActionBtn}" Click="Settings_Click" Margin="3,0"/>
                </UniformGrid>
            </Border>

            <!-- Row separators -->
            <Rectangle Grid.Row="1" VerticalAlignment="Top"    Height="1" Fill="#E8F0FA"/>
            <Rectangle Grid.Row="2" VerticalAlignment="Top"    Height="1" Fill="#E8F0FA"/>
            <Rectangle Grid.Row="3" VerticalAlignment="Top"    Height="1" Fill="#E8F0FA"/>
        </Grid>
    </Border>
</Window>
